<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mission: Chip — Planetary Rover Workshop</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Share+Tech+Mono&family=Exo+2:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #050a14;
    --surface: #0a1628;
    --card: #0d1f3c;
    --border: #1a3a6e;
    --accent: #00d4ff;
    --accent2: #7c3aed;
    --accent3: #10b981;
    --warn: #f59e0b;
    --text: #c8d8f0;
    --text-dim: #5a7a9a;
    --glow: 0 0 20px rgba(0,212,255,0.3);
    --glow2: 0 0 20px rgba(124,58,237,0.3);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Exo 2', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
    line-height: 1.7;
  }

  /* STARFIELD */
  #stars {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .star {
    position: absolute;
    background: white;
    border-radius: 50%;
    animation: twinkle linear infinite;
    opacity: 0;
  }
  @keyframes twinkle {
    0%,100% { opacity: 0; }
    50% { opacity: 0.8; }
  }

  /* SCANLINE OVERLAY */
  body::after {
    content: '';
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.05) 2px, rgba(0,0,0,0.05) 4px);
    pointer-events: none;
    z-index: 1;
  }

  /* LAYOUT */
  .wrapper { position: relative; z-index: 2; max-width: 900px; margin: 0 auto; padding: 0 24px; }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; width: 100%;
    background: rgba(5,10,20,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    z-index: 100;
    padding: 14px 0;
  }
  nav .wrapper { display: flex; align-items: center; gap: 16px; }
  .nav-logo {
    font-family: 'Orbitron', monospace;
    font-size: 14px; font-weight: 700;
    color: var(--accent);
    letter-spacing: 3px;
    text-shadow: var(--glow);
  }
  .nav-dot { width: 6px; height: 6px; background: var(--accent3); border-radius: 50%; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.8)} }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: center;
    padding-top: 80px;
    position: relative;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  @media(max-width:700px){ .hero-grid { grid-template-columns:1fr; } }

  .hero-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 16px;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
  }
  .hero-title {
    font-family: 'Orbitron', monospace;
    font-size: clamp(36px, 7vw, 64px);
    font-weight: 900;
    line-height: 1.1;
    color: #fff;
    opacity: 0;
    animation: fadeUp 0.8s 0.4s forwards;
  }
  .hero-title span { color: var(--accent); text-shadow: var(--glow); }
  .hero-subtitle {
    font-size: 16px; color: var(--text-dim);
    margin: 24px 0 36px;
    opacity: 0;
    animation: fadeUp 0.8s 0.6s forwards;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(0,212,255,0.08);
    border: 1px solid rgba(0,212,255,0.3);
    border-radius: 4px;
    padding: 8px 16px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: var(--accent);
    opacity: 0;
    animation: fadeUp 0.8s 0.8s forwards;
  }

  @keyframes fadeUp {
    from { opacity:0; transform:translateY(20px); }
    to { opacity:1; transform:translateY(0); }
  }

  /* CHIP DISPLAY */
  .chip-display {
    display: flex; flex-direction: column; align-items: center; gap: 16px;
    opacity: 0;
    animation: fadeUp 0.8s 0.5s forwards;
  }
  .oled-screen {
    width: 140px; height: 80px;
    background: #000;
    border-radius: 6px;
    border: 3px solid #333;
    position: relative;
    overflow: hidden;
    box-shadow: 0 0 30px rgba(0,180,255,0.4), inset 0 0 10px rgba(0,0,0,0.8);
  }
  .eye {
    position: absolute;
    background: #00d4ff;
    border-radius: 5px;
    box-shadow: 0 0 10px #00d4ff;
    transition: all 0.3s ease;
  }
  .eye-left { width: 35px; height: 25px; left: 18px; top: 22px; }
  .eye-right { width: 35px; height: 25px; right: 18px; top: 22px; }
  .chip-body {
    width: 160px; height: 100px;
    background: linear-gradient(135deg, #f0f0f0 0%, #d0d0d0 100%);
    border-radius: 12px;
    border: 2px solid #aaa;
    position: relative;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
  }
  .chip-body::before {
    content: '';
    position: absolute;
    inset: 4px;
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 8px;
  }
  .chip-wheels {
    display: flex; justify-content: space-between; width: 200px;
    position: absolute; top: 50%; transform: translateY(-50%);
  }
  .wheel {
    width: 24px; height: 60px;
    background: #222;
    border-radius: 12px;
    border: 2px solid #444;
  }
  .chip-label {
    font-family: 'Orbitron', monospace;
    font-size: 11px; letter-spacing: 3px;
    color: var(--accent); text-shadow: var(--glow);
    text-align: center;
  }

  /* SECTION STYLES */
  section { padding: 80px 0; position: relative; }
  section + section { border-top: 1px solid rgba(26,58,110,0.4); }

  .section-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px; letter-spacing: 4px;
    color: var(--accent2); text-transform: uppercase;
    margin-bottom: 12px;
    display: flex; align-items: center; gap: 12px;
  }
  .section-label::after {
    content: '';
    flex: 1; height: 1px;
    background: linear-gradient(90deg, var(--accent2), transparent);
  }
  .section-title {
    font-family: 'Orbitron', monospace;
    font-size: clamp(22px,4vw,34px);
    font-weight: 700;
    color: #fff; margin-bottom: 12px;
  }
  .section-desc { color: var(--text-dim); font-size: 15px; margin-bottom: 40px; max-width: 600px; }

  /* STORY BOX */
  .story-box {
    background: linear-gradient(135deg, rgba(0,212,255,0.05), rgba(124,58,237,0.05));
    border: 1px solid rgba(0,212,255,0.2);
    border-left: 3px solid var(--accent);
    border-radius: 8px;
    padding: 20px 24px;
    margin-bottom: 32px;
    font-size: 14px;
    color: var(--text);
    position: relative;
  }
  .story-box .story-icon {
    position: absolute; top: -12px; left: 20px;
    background: var(--bg);
    padding: 0 8px;
    font-size: 18px;
  }

  /* COMPONENT CARDS (sensors) */
  .component-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px,1fr)); gap: 20px; margin-bottom: 40px; }
  .component-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s;
  }
  .component-card:hover { border-color: var(--accent); transform: translateY(-4px); }
  .component-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    opacity: 0;
    transition: opacity 0.3s;
  }
  .component-card:hover::before { opacity: 1; }
  .component-icon { font-size: 28px; margin-bottom: 12px; }
  .component-name { font-family: 'Orbitron', monospace; font-size: 13px; color: #fff; margin-bottom: 6px; }
  .component-desc { font-size: 13px; color: var(--text-dim); }

  /* SENSOR SECTIONS */
  .sensor-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px;
    margin-bottom: 32px;
    position: relative;
    overflow: hidden;
  }
  .sensor-section::after {
    content: '';
    position: absolute; bottom: 0; right: 0;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(0,212,255,0.04), transparent 70%);
    pointer-events: none;
  }
  .sensor-header {
    display: flex; align-items: flex-start; gap: 20px; margin-bottom: 24px;
  }
  .sensor-number {
    font-family: 'Orbitron', monospace;
    font-size: 42px; font-weight: 900;
    color: var(--border);
    line-height: 1;
    flex-shrink: 0;
  }
  .sensor-title { font-family: 'Orbitron', monospace; font-size: 20px; color: #fff; margin-bottom: 4px; }
  .sensor-subtitle { font-size: 13px; color: var(--accent); font-family: 'Share Tech Mono', monospace; }

  /* SENSOR SVG ILLUSTRATION */
  .sensor-visual { margin: 24px 0; display: flex; justify-content: center; }

  /* COLLAPSIBLE */
  .collapsible-group { display: flex; flex-direction: column; gap: 8px; margin-top: 20px; }
  .collapse-btn {
    display: flex; align-items: center; gap: 12px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 20px;
    cursor: pointer;
    font-family: 'Exo 2', sans-serif;
    font-size: 14px; font-weight: 500;
    color: var(--text);
    width: 100%; text-align: left;
    transition: all 0.2s;
  }
  .collapse-btn:hover { background: rgba(0,212,255,0.08); border-color: var(--accent); color: #fff; }
  .collapse-btn.active { background: rgba(0,212,255,0.1); border-color: var(--accent); color: #fff; }
  .collapse-btn .btn-icon { font-size: 18px; }
  .collapse-btn .btn-arrow {
    margin-left: auto;
    width: 20px; height: 20px;
    border: 1px solid currentColor;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px;
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .collapse-btn.active .btn-arrow { transform: rotate(180deg); }

  .collapse-content {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.5s cubic-bezier(0.4,0,0.2,1);
    border: 1px solid transparent;
    border-radius: 8px;
  }
  .collapse-content.open {
    max-height: 3000px;
    border-color: var(--border);
  }
  .collapse-inner { padding: 24px; }

  /* CODE BLOCK */
  .code-block {
    background: #02080f;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    margin-top: 12px;
  }
  .code-header {
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(26,58,110,0.4);
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
  }
  .code-lang { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: var(--accent2); letter-spacing: 2px; }
  .copy-btn {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 4px 12px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 1px;
  }
  .copy-btn:hover { background: rgba(0,212,255,0.1); color: var(--accent); border-color: var(--accent); }
  .copy-btn.copied { color: var(--accent3); border-color: var(--accent3); }
  pre {
    padding: 20px;
    overflow-x: auto;
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    line-height: 1.8;
    color: #a8d0f0;
  }
  .kw { color: #7c3aed; }
  .fn { color: #00d4ff; }
  .cm { color: #3a5a7a; font-style: italic; }
  .st { color: #10b981; }
  .nm { color: #f59e0b; }

  /* WIRING DIAGRAM */
  .wiring-diagram-wrap {
    background: #02080f;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
    margin-top: 16px;
    overflow-x: auto;
  }
  .wire-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Share Tech Mono', monospace;
    font-size: 13px;
  }
  .wire-table th {
    text-align: left;
    color: var(--text-dim);
    font-size: 10px; letter-spacing: 2px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
  }
  .wire-table td {
    padding: 10px 12px;
    border-bottom: 1px solid rgba(26,58,110,0.3);
  }
  .wire-table tr:last-child td { border-bottom: none; }
  .wire-dot {
    display: inline-block;
    width: 12px; height: 12px;
    border-radius: 50%; margin-right: 8px; vertical-align: middle;
  }
  .from-pin { color: #fff; }
  .to-pin { color: var(--accent); }

  /* SUCCESS BOX */
  .success-box {
    background: rgba(16,185,129,0.08);
    border: 1px solid rgba(16,185,129,0.3);
    border-radius: 8px;
    padding: 16px 20px;
    font-size: 14px;
    color: var(--accent3);
    margin-top: 20px;
    display: flex; align-items: center; gap: 12px;
  }

  /* PROGRESS STEPS */
  .progress-bar {
    display: flex; gap: 0;
    margin-bottom: 60px;
    overflow-x: auto;
    padding-bottom: 8px;
  }
  .progress-step {
    display: flex; flex-direction: column; align-items: center;
    gap: 8px; flex: 1; min-width: 80px;
    position: relative;
  }
  .progress-step + .progress-step::before {
    content: '';
    position: absolute; top: 14px; left: -50%;
    width: 100%; height: 2px;
    background: var(--border);
  }
  .progress-step.done + .progress-step::before { background: var(--accent3); }
  .step-dot {
    width: 28px; height: 28px;
    border-radius: 50%;
    border: 2px solid var(--border);
    background: var(--bg);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--text-dim);
    position: relative; z-index: 1;
    transition: all 0.3s;
  }
  .progress-step.done .step-dot {
    border-color: var(--accent3); background: rgba(16,185,129,0.15);
    color: var(--accent3);
  }
  .progress-step.current .step-dot {
    border-color: var(--accent); background: rgba(0,212,255,0.15);
    color: var(--accent);
    box-shadow: var(--glow);
  }
  .step-label { font-size: 10px; color: var(--text-dim); text-align: center; letter-spacing: 1px; }

  /* MISSION SECTION */
  .mission-card {
    background: linear-gradient(135deg, rgba(0,212,255,0.06), rgba(124,58,237,0.06));
    border: 1px solid rgba(0,212,255,0.25);
    border-radius: 12px;
    padding: 32px;
    text-align: center;
    margin-bottom: 32px;
  }
  .mission-icon { font-size: 48px; margin-bottom: 16px; }
  .mission-title { font-family: 'Orbitron', monospace; font-size: 24px; color: #fff; margin-bottom: 12px; }
  .mission-desc { color: var(--text-dim); font-size: 15px; max-width: 500px; margin: 0 auto; }

  /* FOOTER */
  footer {
    padding: 40px 0;
    text-align: center;
    border-top: 1px solid var(--border);
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 2px;
  }

  /* CHIP ANIMATED ROVER */
  .chip-rover-wrap {
    display: flex; justify-content: center; align-items: center;
    margin: 40px 0;
  }

  /* EXPERIMENT CHALLENGE */
  .challenge-box {
    background: rgba(245,158,11,0.06);
    border: 1px solid rgba(245,158,11,0.3);
    border-left: 3px solid var(--warn);
    border-radius: 8px;
    padding: 20px 24px;
    margin-top: 20px;
  }
  .challenge-title {
    font-family: 'Orbitron', monospace;
    font-size: 12px; color: var(--warn);
    letter-spacing: 2px; margin-bottom: 10px;
  }
  .challenge-desc { font-size: 14px; color: var(--text); }

  /* SCROLL REVEAL */
  .reveal {
    opacity: 0; transform: translateY(30px);
    transition: opacity 0.7s, transform 0.7s;
  }
  .reveal.visible { opacity: 1; transform: none; }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  /* LIBRARY TAGS */
  .lib-tag {
    display: inline-block;
    background: rgba(124,58,237,0.15);
    border: 1px solid rgba(124,58,237,0.4);
    border-radius: 4px;
    padding: 3px 10px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--accent2);
    margin: 4px 4px 4px 0;
  }

</style>
</head>
<body>

<!-- Starfield -->
<div id="stars"></div>

<!-- NAV -->
<nav>
  <div class="wrapper">
    <div class="nav-dot"></div>
    <div class="nav-logo">MISSION : CHIP</div>
    <div style="margin-left:auto; font-family:'Share Tech Mono',monospace; font-size:11px; color:var(--text-dim);">PLANETARY ROVER WORKSHOP</div>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="wrapper">
    <div class="hero-grid">
      <div>
        <div class="hero-label">// DAY 01 — SYSTEMS BOOT</div>
        <h1 class="hero-title">Meet<br><span>Chip.</span></h1>
        <p class="hero-subtitle">A small rover on a big mission. Today we build him from scratch, wire him up, and send him off to explore a distant planet.</p>
        <div class="hero-badge">
          <span style="width:8px;height:8px;background:var(--accent3);border-radius:50%;display:inline-block;animation:pulse 1.5s infinite;"></span>
          WORKSHOP IN PROGRESS
        </div>
      </div>
      <div class="chip-display">
        <!-- Animated Chip Rover -->
        <svg width="220" height="260" viewBox="0 0 220 260" fill="none" xmlns="http://www.w3.org/2000/svg" id="chip-svg">
          <!-- Body -->
          <rect x="40" y="130" width="140" height="90" rx="14" fill="#e8ecf0" stroke="#c0c8d0" stroke-width="2"/>
          <!-- Body detail lines -->
          <line x1="50" y1="155" x2="170" y2="155" stroke="#b0b8c0" stroke-width="1"/>
          <circle cx="60" cy="145" r="3" fill="#a0a8b0"/>
          <circle cx="160" cy="145" r="3" fill="#a0a8b0"/>
          <!-- Wheels left -->
          <rect x="16" y="148" width="26" height="60" rx="13" fill="#1a2030" stroke="#2a3040" stroke-width="2"/>
          <line x1="29" y1="148" x2="29" y2="208" stroke="#2a3040" stroke-width="1" stroke-dasharray="4 4"/>
          <!-- Wheels right -->
          <rect x="178" y="148" width="26" height="60" rx="13" fill="#1a2030" stroke="#2a3040" stroke-width="2"/>
          <line x1="191" y1="148" x2="191" y2="208" stroke="#2a3040" stroke-width="1" stroke-dasharray="4 4"/>
          <!-- Neck -->
          <rect x="90" y="100" width="40" height="35" rx="4" fill="#d0d8e0" stroke="#b0b8c0" stroke-width="1.5"/>
          <!-- Head / OLED area -->
          <rect x="55" y="30" width="110" height="80" rx="12" fill="#1a2030" stroke="#2a3040" stroke-width="2"/>
          <rect x="67" y="42" width="86" height="56" rx="6" fill="#000" stroke="#1a3040" stroke-width="1.5"/>
          <!-- OLED glow -->
          <rect id="eye-l" x="75" y="55" width="32" height="22" rx="5" fill="#00d4ff" opacity="0.9"/>
          <rect id="eye-r" x="115" y="55" width="32" height="22" rx="5" fill="#00d4ff" opacity="0.9"/>
          <!-- Antenna -->
          <line x1="110" y1="30" x2="110" y2="12" stroke="#a0a8b0" stroke-width="2"/>
          <circle cx="110" cy="10" r="4" fill="none" stroke="#00d4ff" stroke-width="2">
            <animate attributeName="opacity" values="1;0.2;1" dur="2s" repeatCount="indefinite"/>
          </circle>
          <!-- Front sensor bar -->
          <rect x="72" y="165" width="76" height="16" rx="4" fill="#0a1628" stroke="#1a3a6e" stroke-width="1.5"/>
          <circle cx="89" cy="173" r="3" fill="#00d4ff" opacity="0.7">
            <animate attributeName="opacity" values="0.7;0.2;0.7" dur="1.5s" repeatCount="indefinite"/>
          </circle>
          <rect cx="105" cy="173" x="103" y="168" width="14" height="10" rx="2" fill="#10b981" opacity="0.5"/>
          <circle cx="121" cy="173" r="3" fill="#f59e0b" opacity="0.6">
            <animate attributeName="opacity" values="0.6;0.1;0.6" dur="2.2s" repeatCount="indefinite"/>
          </circle>
        </svg>
        <div class="chip-label">C H I P — MK.1</div>
      </div>
    </div>
  </div>
</section>

<!-- THE MISSION -->
<section id="mission">
  <div class="wrapper">
    <div class="section-label">// CHAPTER 00</div>
    <h2 class="section-title reveal">The Mission</h2>
    <div class="story-box reveal">
      <span class="story-icon">🛸</span>
