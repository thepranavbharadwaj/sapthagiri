  pinMode(L1,OUTPUT); pinMode(L2,OUTPUT);
  pinMode(R1,OUTPUT); pinMode(R2,OUTPUT);
  pinMode(sensorPin,INPUT);
}

void loop() {
  if(digitalRead(sensorPin) == LOW) {
    stopBot();   delay(200);
    backward();  delay(500);
    stopBot();   delay(200);
    slightRight(); delay(400);
