              <pre id="code-oled">#include &lt;Wire.h&gt;
#include &lt;Adafruit_GFX.h&gt;
#include &lt;Adafruit_SSD1306.h&gt;

#define W 128
#define H 64
Adafruit_SSD1306 display(W, H, &Wire, -1);

float eyeX = 0, eyeY = 0;
float targetX = 0, targetY = 0;
unsigned long lastMove = 0, lastBlink = 0;
bool blinking = false;
int blinkFrame = 0;

void chooseNewTarget() {
  targetX = random(-8, 9);
  targetY = random(-4, 5);
}

void updateWander() {
  if (millis() - lastMove > random(1200, 2200)) {
    chooseNewTarget();
    lastMove = millis();
  }
  eyeX += (targetX - eyeX) * 0.05;
  eyeY += (targetY - eyeY) * 0.05;
}

void updateBlink() {
  if (!blinking) return;
  blinkFrame++;
  if (blinkFrame > 4) blinking = false;
}

void drawEyes() {
  int leftX = 26 + eyeX;
  int rightX = 70 + eyeX;
  int y = 22 + eyeY;

  if (blinking) {
    display.fillRoundRect(leftX, y+10, 30, 4, 2, WHITE);
    display.fillRoundRect(rightX, y+10, 30, 4, 2, WHITE);
    return;
  }
  display.fillRoundRect(leftX, y, 30, 22, 8, WHITE);
  display.fillRoundRect(rightX, y, 30, 22, 8, WHITE);
}

void setup() {
  Wire.begin();
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  chooseNewTarget();
}

void loop() {
  unsigned long now = millis();

  if (now - lastBlink > 3000) {
    blinking = true;
    blinkFrame = 0;
    lastBlink = now;
  }

  updateBlink();
  updateWander();
  display.clearDisplay();
  drawEyes();
  display.display();
  delay(40);
}</pre>
