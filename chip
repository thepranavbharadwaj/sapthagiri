            <div class="code-header"><span class="code-lang">ARDUINO C++ — FULL MISSION PROGRAM</span><button class="copy-btn" onclick="copyCode(this)">COPY</button></div>
            <pre>#include &lt;Wire.h&gt;
#include &lt;Adafruit_GFX.h&gt;
#include &lt;Adafruit_SSD1306.h&gt;
#include &lt;DHT.h&gt;

#define W 128
#define H 64
Adafruit_SSD1306 display(W, H, &Wire, -1);

#define DHTPIN 4
#define DHTTYPE DHT11
#define LDRPIN 3
DHT dht(DHTPIN, DHTTYPE);

// Motor pins
int L1=5, L2=6, R1=9, R2=10;
int irSensor = 2;
int speedSlow = 100;

// Robot state machine
int robotState = 0;
unsigned long stateStart = 0;
int turnDirection = 0;

// Eye animation
float eyeX=0, eyeY=0, targetX=0, targetY=0;
unsigned long lastMove=0;
bool blinking=false;
int blinkFrame=0;
unsigned long lastBlink=0;

// Obstacle expression
bool obstacleExpression=false;
unsigned long obstacleTimer=0;

// Timing
unsigned long lastFrame=0, lastDHTRead=0;
float temp=0, hum=0;

// LATCH — once beacon found, never go back
bool scienceModeLocked = false;

void stopBot()    { analogWrite(L1,0);         analogWrite(L2,0);         analogWrite(R1,0);         analogWrite(R2,0); }
void forward()    { analogWrite(L1,0);         analogWrite(L2,speedSlow); analogWrite(R1,0);         analogWrite(R2,speedSlow); }
void backward()   { analogWrite(L1,speedSlow); analogWrite(L2,0);         analogWrite(R1,speedSlow); analogWrite(R2,0); }
void slightRight(){ analogWrite(L1,0);         analogWrite(L2,speedSlow); analogWrite(R1,speedSlow/2); analogWrite(R2,0); }
void slightLeft() { analogWrite(L1,speedSlow/2); analogWrite(L2,0);       analogWrite(R1,0);         analogWrite(R2,speedSlow); }

void chooseNewTarget() {
  targetX = random(-8, 9);
  targetY = random(-4, 5);
}

void updateEyes() {
  unsigned long now = millis();
  if(now - lastMove > random(1200, 2200)) { chooseNewTarget(); lastMove=now; }
  eyeX += (targetX - eyeX) * 0.05;
  eyeY += (targetY - eyeY) * 0.05;
  if(now - lastBlink > 3500) { blinking=true; blinkFrame=0; lastBlink=now; }
  if(blinking) { blinkFrame++; if(blinkFrame>3) blinking=false; }
}

void drawEyes() {
  int leftX = 26+eyeX, rightX = 70+eyeX, y = 22+eyeY;
  if(obstacleExpression) {
    display.fillRoundRect(leftX, y-5, 30, 30, 5, WHITE);
    display.fillRoundRect(rightX, y-5, 30, 30, 5, WHITE);
    return;
  }
  if(blinking) {
    display.fillRoundRect(leftX, y+12, 30, 4, 2, WHITE);
    display.fillRoundRect(rightX, y+12, 30, 4, 2, WHITE);
    return;
  }
  display.fillRoundRect(leftX, y, 30, 22, 8, WHITE);
  display.fillRoundRect(rightX, y, 30, 22, 8, WHITE);
}

void setup() {
  pinMode(L1,OUTPUT); pinMode(L2,OUTPUT);
  pinMode(R1,OUTPUT); pinMode(R2,OUTPUT);
  pinMode(irSensor,INPUT);
  pinMode(LDRPIN,INPUT);
  Wire.begin();
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  dht.begin();
  randomSeed(analogRead(A0));
  chooseNewTarget();
}

void loop() {
  // Check for beacon
  if(digitalRead(LDRPIN) == LOW) {
    scienceModeLocked = true;
    stopBot();
  }

  if(scienceModeLocked) {
    // Science mode — display readings forever
    if(millis() - lastDHTRead > 1200) {
      hum  = dht.readHumidity();
      temp = dht.readTemperature();
      lastDHTRead = millis();
    }
    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(WHITE);
    display.setCursor(0, 0);  display.print("TEMP");
    display.setCursor(0, 20); display.print(temp); display.print(" C");
    display.setCursor(0, 40); display.print("HUM ");
    display.setCursor(60,40); display.print(hum);  display.print(" %");
    display.display();
  }
  else {
    // Explore mode
    int obstacle = digitalRead(irSensor);
    unsigned long now = millis();

    switch(robotState) {
      case 0: // Forward
        if(obstacle==LOW) {
          obstacleExpression=true; obstacleTimer=now;
          stopBot();
          turnDirection = random(0,2);
          robotState=1; stateStart=now;
        } else { forward(); }
        break;
      case 1: // Back up
        backward();
        if(now-stateStart>400) { robotState=2; stateStart=now; }
        break;
      case 2: // Turn
        if(turnDirection==0) slightLeft(); else slightRight();
        if(now-stateStart>350) robotState=0;
        break;
    }

    if(obstacleExpression && millis()-obstacleTimer>800)
      obstacleExpression=false;

    if(millis()-lastFrame>40) {
      display.clearDisplay();
      updateEyes();
      drawEyes();
      display.display();
      lastFrame=millis();
    }
  }
}</pre>
