    setTimeout(doBlink, 2500+Math.random()*2000);
  }
  setTimeout(doBlink, 1000);
}
startBlink();

// EYE WANDER
let wx=0,wy=0,txe=0,tye=0;
let lastWander=Date.now();
function wanderEyes(){
  if(Date.now()-lastWander>1500){
    txe=Math.random()*10-5;
    tye=Math.random()*6-3;
    lastWander=Date.now()+Math.random()*800;
  }
  wx+=(txe-wx)*0.05;
  wy+=(tye-wy)*0.05;
  const el=document.getElementById('eye-l');
  const er=document.getElementById('eye-r');
  if(el&&er){
    el.setAttribute('x',75+wx);
    er.setAttribute('x',115+wx);
    el.setAttribute('y',55+wy);
    er.setAttribute('y',55+wy);
  }
  requestAnimationFrame(wanderEyes);
}
wanderEyes();
