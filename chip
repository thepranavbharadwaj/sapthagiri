void forward()   { analogWrite(L1,0);         analogWrite(L2,speedSlow); analogWrite(R1,0);         analogWrite(R2,speedSlow); }
void backward()  { analogWrite(L1,speedSlow); analogWrite(L2,0);         analogWrite(R1,speedSlow); analogWrite(R2,0); }
void slightRight(){ analogWrite(L1,0);        analogWrite(L2,speedSlow); analogWrite(R1,speedSlow/2); analogWrite(R2,0); }
